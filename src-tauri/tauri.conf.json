{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mtool",
  "version": "1.0.7",
  "identifier": "com.mayuanfei.mtool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MTOOL",
        "width": 800,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; img-src 'self' asset: https: http: data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost asset: https: http:",
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4OUM4MDI0QjJDOTUyNDMKUldSRFVzbXlKSUNjNkUwN21aRG1vWFR5OVBBaHAxaUlXdkRQK2Fkc2p0T2cvU1lUaVAramdMMkUK",
      "endpoints": [
        "https://github.com/mayuanfei/mtool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "nsis"],
    "resources": [
      "resources/cfr-0.152.jar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "infoPlist": "Info.plist"
    }
  }
}
